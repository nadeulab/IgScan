\item Parse BCR = "bcr_annotation_airr.tsv"
\item BD Rhapsody BCR = "Contigs_AIRR.tsv"
\item MiXCR = "clonotypes.IGX.txt"
\item TRUST4 = "barcode_report.tsv"
\item AIRR = "airr_rearrangement.tsv"
\item IMGT AIRR = "vquest_airr.tsv"
\item fasta
